# ─────────────────────────────────────────────────────────────────────────────
# Moneto web (landing) · environment template
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy to `.env.local` (gitignored) y llenar valores.
#   cp apps/web/.env.example apps/web/.env.local
#
# Next.js convention:
#   • `NEXT_PUBLIC_*` se embeben en el bundle del browser — públicos.
#   • Sin prefijo → solo accesibles en server (Server Components, route
#     handlers). NUNCA importar server vars desde un Client Component.
#
# Vercel: configurar las mismas vars en Project Settings → Environment Variables
# por env (Production / Preview / Development).
#
# ─────────────────────────────────────────────────────────────────────────────

# Public — embebidos en el bundle del browser.
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Observability — DSN/keys públicas.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# Server-only (no `NEXT_PUBLIC_` prefix). Usados en route handlers o
# Server Components. NUNCA exponer al cliente.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=
