{
  "expo": {
    "name": "Moneto",
    "slug": "moneto",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "moneto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moneto.app",
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Moneto usa Face ID para proteger tu saldo privado y autorizar transacciones de forma segura.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": false,
          "NSAllowsArbitraryLoadsForMedia": false,
          "NSAllowsArbitraryLoadsInWebContent": false,
          "NSPinnedDomains": {
            "moneto.xyz": {
              "NSIncludesSubdomains": true,
              "NSPinnedCAIdentities": []
            }
          }
        },
        "NSCameraUsageDescription": "Moneto usa la cámara solo para verificación KYC (selfie + documento). Nunca se accede sin tu permiso explícito.",
        "NSPhotoLibraryUsageDescription": "Moneto puede pedir una foto de tu documento para verificación KYC. Nada se guarda localmente."
      }
    },
    "android": {
      "package": "com.moneto.app",
      "userInterfaceStyle": "automatic",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_CALENDAR"
      ]
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#14100B"
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#14100B"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Moneto usa Face ID para proteger tu saldo privado."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "usesCleartextTraffic": false,
            "networkSecurityConfig": {
              "cleartextTrafficPermitted": false,
              "domain-config": [
                {
                  "domain": "moneto.xyz",
                  "includeSubdomains": true,
                  "cleartextTrafficPermitted": false
                }
              ]
            }
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "@privy-io/expo-native-extensions"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "backgroundColor": "#14100B",
      "resizeMode": "contain"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "041abd0d-04a0-4217-8379-12f668477763"
      }
    },
    "owner": "davidzo"
  }
}
