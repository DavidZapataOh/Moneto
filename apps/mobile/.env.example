# ─────────────────────────────────────────────────────────────────────────────
# Moneto mobile · environment template
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env.local` and fill in real values for your env.
#   cp apps/mobile/.env.example apps/mobile/.env.local
#
# WARNING — Expo / Metro:
#   Solo variables con prefijo `EXPO_PUBLIC_*` quedan disponibles en el bundle
#   (`process.env.EXPO_PUBLIC_X`). TODO lo que pongas aquí se embebe en el JS
#   bundle y es REVERSE-ENGINEERABLE. Nunca poner aquí service-role keys,
#   secrets de backend, ni JWT signing keys. Solo identificadores públicos
#   (Privy app ID, Supabase anon key, RPC URLs, Sentry DSN).
#
# Donde viven los secrets reales:
#   • Vault del equipo (1Password "Moneto Engineering" — pedirle al founder).
#   • EAS env vars per build profile (`apps/mobile/eas.json`).
#
# ─────────────────────────────────────────────────────────────────────────────

# Environment selector — afecta endpoints, keys, y log verbosity.
# Valores: development | staging | production
EXPO_PUBLIC_ENV=development

# Backend API base URL. Mobile pega aquí para auth, viewing keys, payroll, etc.
#   dev:        http://localhost:8787
#   staging:    https://api-staging.moneto.xyz
#   production: https://api.moneto.xyz
EXPO_PUBLIC_API_URL=http://localhost:8787

# ── Privy (embedded wallets + auth) ─────────────────────────────────────────
# App ID público del environment correspondiente.
# Crear en https://dashboard.privy.io.
EXPO_PUBLIC_PRIVY_APP_ID=clxxxxxxxxxxxxxxxx-dev
# Client ID público (opcional; algunos flows lo requieren).
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# ── Solana RPC ──────────────────────────────────────────────────────────────
# Helius (paid tier en mainnet). En devnet podemos usar el endpoint público.
#   dev/staging: https://devnet.helius-rpc.com/?api-key=<HELIUS_KEY_DEVNET>
#   production:  https://mainnet.helius-rpc.com/?api-key=<HELIUS_KEY_MAINNET>
EXPO_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_DEVNET_KEY
# Network selector — debe coincidir con la URL de arriba.
# Valores: devnet | mainnet-beta
EXPO_PUBLIC_SOLANA_NETWORK=devnet

# ── Supabase (compartmentalized identity) ───────────────────────────────────
# URL del proyecto + anon key (público). Nunca poner el service-role key aquí.
# Crear proyectos: moneto-dev / moneto-staging / moneto-prod en supabase.com.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Observability (opcional pero recomendado para staging+) ─────────────────
# Sentry — error reporting. DSN es público pero único por proyecto.
EXPO_PUBLIC_SENTRY_DSN=
# PostHog — product analytics. Key pública.
EXPO_PUBLIC_POSTHOG_KEY=
