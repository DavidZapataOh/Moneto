{
  "$schema": "https://json.schemastore.org/eas.json",
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "base": {
      "node": "20.18.1",
      "pnpm": "9.15.9",
      "env": {
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_API_URL": "http://localhost:8787"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://api-staging.moneto.xyz"
      }
    },
    "staging": {
      "extends": "preview",
      "channel": "staging"
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.moneto.xyz"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "founder@moneto.xyz",
        "ascAppId": "TBD",
        "appleTeamId": "TBD"
      }
    },
    "production": {
      "ios": {
        "appleId": "founder@moneto.xyz",
        "ascAppId": "TBD",
        "appleTeamId": "TBD"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
